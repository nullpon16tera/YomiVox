<Window x:Class="YomiVox.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YomiVox — オプション"
        Height="900" Width="820"
        MinHeight="560" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Padding="24,8" MinWidth="100" Click="Ok_Click"/>
            <Button Content="キャンセル" IsCancel="True" Padding="24,8" MinWidth="100" Margin="8,0,0,0" Click="Cancel_Click"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="176"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SettingsNavList" Grid.Column="0" Margin="0,0,12,0"
                     BorderThickness="1" BorderBrush="#DDD" Background="#F8F8F8"
                     SelectionChanged="SettingsNavList_OnSelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem Content="全般"/>
                <ListBoxItem Content="Twitch"/>
                <ListBoxItem>
                    <TextBlock Text="Beat Saber" TextWrapping="Wrap"
                               ToolTip="定型チャットコマンド（!bsr・カスタム読み上げの声）"/>
                </ListBoxItem>
                <ListBoxItem Content="キャラクター"/>
            </ListBox>

            <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" Padding="12,8,12,12" Background="White">
                <Grid>
                    <ScrollViewer x:Name="ScrollGeneral" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#444" FontSize="12">
                                VOICEVOX エンジンと再生先・音量です。チャンネル接続はメイン画面から行います。
                            </TextBlock>

                            <GroupBox Header="VOICEVOX / 音声出力" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">エンジン URL</TextBlock>
                                    <DockPanel Grid.Row="0" Grid.Column="1" Margin="4">
                                        <TextBox x:Name="VoicevoxUrlBox" Text="http://127.0.0.1:50021/" VerticalAlignment="Center"/>
                                        <Button Content="話者を再取得" Click="RefreshSpeakers_Click" Margin="8,0,0,0" Padding="12,4"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0">再生デバイス</TextBlock>
                                    <ComboBox x:Name="AudioDeviceCombo" Grid.Row="1" Grid.Column="1" Margin="4,8,4,0"
                                              ToolTip="普段使いのスピーカー／ヘッドホンでOK。OBS は「アプリケーション音声キャプチャ」で YomiVox を選ぶと VB-Cable 不要（README 参照）。"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0">読み上げ音量</TextBlock>
                                    <DockPanel Grid.Row="2" Grid.Column="1" Margin="4,8,4,0">
                                        <TextBlock x:Name="VolumePercentLabel" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0" MinWidth="52" Text="250%"/>
                                        <Slider x:Name="VolumeSlider" Minimum="50" Maximum="400" Value="250" AutoToolTipPlacement="TopLeft"
                                                ToolTip="VOICEVOX からの波形を再生前に増幅します。100%=等倍、400%=最大約4倍（音割れしやすい）"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" Margin="0,12,0,0">話者プール</TextBlock>
                                    <TextBlock x:Name="SpeakersStatus" Grid.Row="3" Grid.Column="1" Margin="4,12,4,0" TextWrapping="Wrap"
                                               Text="未取得"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="ScrollTwitch" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel x:Name="PanelTwitch">
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#444">
                                「ブラウザでログイン」で Twitch にサインインすると、OAuth トークンとログイン名を自動で入れられます（Client ID と OAuth リダイレクト URL の登録が必要）。
                            </TextBlock>

                            <GroupBox Header="Twitch" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">Client ID</TextBlock>
                                    <TextBox x:Name="ClientIdBox" Grid.Row="0" Grid.Column="1" Margin="4"
                                             ToolTip="dev.twitch.tv のアプリ登録で発行される値。ブラウザログインに必須。"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">Client Secret</TextBlock>
                                    <PasswordBox x:Name="ClientSecretBox" Grid.Row="1" Grid.Column="1" Margin="4"
                                                 ToolTip="一覧では出ません。アプリの Manage を開き「New Secret」で生成した値を貼る。トークン取得 400 のときに必要。"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" Margin="0,4">OAuth リダイレクト</TextBlock>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="4,4,4,0" TextWrapping="Wrap" FontSize="11" Foreground="#555">
                                        <Run Text="Twitch Developer Console のアプリ設定で「OAuth リダイレクト URL」に "/>
                                        <Run FontFamily="Consolas" FontWeight="Bold" Text="https://127.0.0.1:17563/"/>
                                        <Run Text=" を追加して保存してください（末尾スラッシュ含む）。"/>
                                    </TextBlock>

                                    <Button x:Name="BrowserLoginBtn" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left" Margin="4,6,0,4"
                                            Content="ブラウザで Twitch にログインしてトークンを取得" Padding="14,8" Click="BrowserLogin_Click"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">Twitch ログイン名</TextBlock>
                                    <TextBox x:Name="TwitchLoginBox" Grid.Row="4" Grid.Column="1" Margin="4"
                                             ToolTip="ブラウザログイン後に自動入力されます。手入力も可。"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">OAuth トークン</TextBlock>
                                    <PasswordBox x:Name="OAuthBox" Grid.Row="5" Grid.Column="1" Margin="4" MinWidth="280"
                                                 VerticalAlignment="Center" VerticalContentAlignment="Center"/>

                                    <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="4,4,4,0" VerticalAlignment="Center">
                                        <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#666" Text="手動の場合: oauth: は自動付与。参考 →"/>
                                        <Button Content="dev.twitch.tv" Click="OpenTwitchDev_Click" Margin="6,0,0,0" Padding="10,2" VerticalAlignment="Center"/>
                                        <Button Content="ドキュメント" Click="OpenTokenHelp_Click" Margin="6,0,0,0" Padding="10,2" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="7" Grid.Column="1" Margin="4,8,4,0" TextWrapping="Wrap" FontSize="11" Foreground="#666">
                                        チャンネル URL とチャット接続（行ごとの「接続」）はメイン画面から行います。
                                    </TextBlock>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="ユーザー名の読み上げ" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <CheckBox x:Name="ReadUsernameAloudCheck" Content="チャット本文の前にユーザー名を読み上げる" Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#555" Margin="0,0,0,6"
                                               Text="「{}{UserName}」は、!readname の登録があればそれを、なければ Twitch の表示名（なければログイン名）に置き換わります。"/>
                                    <TextBlock Text="テンプレート" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UsernameSpeechTemplateBox"
                                             ToolTip="例: {}{UserName} さん、 / {}{UserName}、 / {}{UserName} から "/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="配信者のチャットの声" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="11" Foreground="#555">
                                        Twitch の「ログイン名」と同じユーザーが送った通常チャットの読み上げに使います。視聴者のランダム割当・!voice とは別設定です。配信者の !voice は使わず、ここで選んでください。
                                    </TextBlock>

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">話者（キャラ）</TextBlock>
                                    <ComboBox x:Name="BroadcasterCharacterCombo" Grid.Row="1" Grid.Column="1" Margin="4"
                                              IsEditable="False"
                                              SelectionChanged="BroadcasterCharacterCombo_OnSelectionChanged"
                                              ToolTip="VOICEVOX の「話者を再取得」後に一覧が入ります。"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">スタイル</TextBlock>
                                    <ComboBox x:Name="BroadcasterStyleCombo" Grid.Row="2" Grid.Column="1" Margin="4"
                                              IsEditable="False"
                                              ToolTip="選択したキャラのスタイル。"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="チャットボットの声" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="11" Foreground="#555">
                                        Nightbot や StreamElements などのボットのログイン名を指定すると、そのユーザーからの通常チャットはここで選んだ話者で固定して読み上げます（視聴者のランダム割当・!voice とは別。複数はカンマ区切り）。
                                    </TextBlock>

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">ボット名</TextBlock>
                                    <TextBox x:Name="ChatBotUsernamesBox" Grid.Row="1" Grid.Column="1" Margin="4"
                                             ToolTip="例: nightbot, streamelements（カンマ区切り・複数可、前後の空白は無視）"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,4,4">話者（キャラ）</TextBlock>
                                    <ComboBox x:Name="ChatBotCharacterCombo" Grid.Row="2" Grid.Column="1" Margin="4,8,4,4"
                                              IsEditable="False"
                                              SelectionChanged="ChatBotCharacterCombo_OnSelectionChanged"
                                              ToolTip="上記ボットの通常チャットの読み上げに使うキャラ。"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">スタイル</TextBlock>
                                    <ComboBox x:Name="ChatBotStyleCombo" Grid.Row="3" Grid.Column="1" Margin="4"
                                              IsEditable="False"
                                              ToolTip="上記ボットの通常チャットの読み上げに使うスタイル。"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="ScrollBeatSaber" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#444" FontSize="12">
                                !bsr や「ツール」→「カスタムコマンド」の定型読み上げに使う声です。配信者の通常チャット用とは別に選べます。
                            </TextBlock>

                            <GroupBox Header="定型チャットコマンド（!bsr・カスタム）" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">話者（キャラ）</TextBlock>
                                    <ComboBox x:Name="FixedCharacterCombo" Grid.Row="0" Grid.Column="1" Margin="4"
                                              IsEditable="False"
                                              SelectionChanged="FixedCharacterCombo_OnSelectionChanged"
                                              ToolTip="定型読み上げ専用のキャラ。"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,4">スタイル</TextBlock>
                                    <ComboBox x:Name="FixedStyleCombo" Grid.Row="1" Grid.Column="1" Margin="4"
                                              IsEditable="False"
                                              ToolTip="定型読み上げ専用のスタイル。"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,4">!bsr の読み上げ文</TextBlock>
                                    <TextBox x:Name="BeatSaberBsrTextBox" Grid.Row="2" Grid.Column="1" Margin="4,8,4,4"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="44"
                                             ToolTip="チャットで !bsr が来たときに読み上げる内容（コマンド本文は読まずこの文だけ）。"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="11" Foreground="#555">
                                        !bsr は Beat Saber のリクエスト用コマンドです。視聴者の通常チャットは従来どおりランダムキャラ＋!voice です。
                                    </TextBlock>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="ScrollCharacter" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap" Margin="0,0,0,10"
                                       Foreground="#444" FontSize="12">
                                VOICEVOX の話者キャラごとに、話速・音高・抑揚・音量を調整できます（未変更の項目はエンジン既定のまま）。話者一覧は「全般」の「話者を再取得」後に更新されます。
                            </TextBlock>

                            <ListBox x:Name="CharacterSynthList" Grid.Row="1" Grid.Column="0" Margin="0,0,12,0"
                                     BorderThickness="1" BorderBrush="#DDD" Background="#F8F8F8"
                                     MinHeight="280"
                                     SelectionChanged="CharacterSynthList_OnSelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <Border x:Name="CharacterSynthPanel" Grid.Row="1" Grid.Column="1" IsEnabled="False"
                                    BorderBrush="#E8E8E8" BorderThickness="1" Padding="12" Background="#FAFAFA">
                                <StackPanel>
                                    <TextBlock x:Name="CharacterSynthTitle" Text="キャラを選択してください" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <TextBlock x:Name="SpeedSynthLabel" Text="話速 1.00" Margin="0,0,0,4"/>
                                    <Slider x:Name="SpeedSynthSlider" Minimum="0.5" Maximum="2" Value="1" TickFrequency="0.05"
                                            IsSnapToTickEnabled="False" AutoToolTipPlacement="TopLeft"
                                            ValueChanged="CharacterSynthSlider_OnValueChanged"/>

                                    <TextBlock x:Name="PitchSynthLabel" Text="音高 0.00" Margin="0,12,0,4"/>
                                    <Slider x:Name="PitchSynthSlider" Minimum="-0.15" Maximum="0.15" Value="0"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="CharacterSynthSlider_OnValueChanged"/>

                                    <TextBlock x:Name="IntonationSynthLabel" Text="抑揚 1.00" Margin="0,12,0,4"/>
                                    <Slider x:Name="IntonationSynthSlider" Minimum="0" Maximum="2" Value="1" TickFrequency="0.05"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="CharacterSynthSlider_OnValueChanged"/>

                                    <TextBlock x:Name="VolumeSynthLabel" Text="音量 1.00" Margin="0,12,0,4"/>
                                    <Slider x:Name="VolumeSynthSlider" Minimum="0" Maximum="2" Value="1" TickFrequency="0.05"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="CharacterSynthSlider_OnValueChanged"/>

                                    <Button Content="このキャラをエンジン既定に戻す" Margin="0,16,0,0" HorizontalAlignment="Left"
                                            Padding="12,6" Click="CharacterSynthResetDefaults_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
