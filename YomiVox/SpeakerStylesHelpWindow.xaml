<Window x:Class="YomiVox.SpeakerStylesHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="話者とスタイル一覧"
        Height="560" Width="440"
        MinHeight="320" MinWidth="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="クリップボードにコピー" Padding="14,8" MinWidth="160" Click="CopyAll_Click"/>
            <Button Content="閉じる" IsCancel="True" Padding="14,8" MinWidth="90" Margin="8,0,0,0" Click="Close_Click"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#444" FontSize="12">
            VOICEVOX から取得した話者キャラとスタイルです。Ctrl+A で全選択してコピーできます。一覧が空のときは「ツール」→「オプション」→「全般」で「話者を再取得」してください。
        </TextBlock>
        <TextBox x:Name="BodyText"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Segoe UI"
                 FontSize="13"
                 Padding="8"/>
    </DockPanel>
</Window>
