<Window x:Class="YomiVox.CustomCommandsSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="カスタムコマンド（定型読み上げ）"
        Height="560" Width="720"
        MinHeight="400" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Padding="20,8" MinWidth="90" Click="Ok_Click"/>
            <Button Content="キャンセル" IsCancel="True" Padding="20,8" MinWidth="90" Margin="8,0,0,0" Click="Cancel_Click"/>
        </StackPanel>

        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,8">
            <Button Content="行を追加" Click="AddRow_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="選択行を削除" Click="RemoveSelected_Click" Padding="12,6"/>
        </DockPanel>

        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#444" FontSize="12">
            チャットが「コマンド」で始まるとき、返答文だけを読み上げます（コマンド本文は読みません）。長いコマンドを先に判定します。
            読み上げ声は「ツール」→「オプション」→「Beat Saber」タブの「定型チャットコマンド（!bsr・カスタム）」で選んだ話者・スタイルに従います（配信者の通常チャット用とは別）。
        </TextBlock>

        <DataGrid x:Name="CommandsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8F8F8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="コマンド（先頭一致）"
                                    Binding="{Binding CommandTrigger, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
                <DataGridTextColumn Header="返答の読み上げ文"
                                    Binding="{Binding ResponseText, UpdateSourceTrigger=PropertyChanged}"
                                    Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
